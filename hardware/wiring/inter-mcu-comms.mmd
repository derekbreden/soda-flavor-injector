flowchart LR

  %% ═══════════════════════════════════════
  %%  Inter-MCU Communication — Current Prototype
  %% ═══════════════════════════════════════

  subgraph ESP32["ESP32-DevKitC-32E\n(Main Controller)"]
    direction TB
    E_S2_TX["GPIO 32  Serial2 TX"]
    E_S2_RX["GPIO 35  Serial2 RX\n(input-only)"]
    E_S1_TX["GPIO 15  Serial1 TX"]
    E_S1_RX["GPIO 34  Serial1 RX\n(input-only)"]
  end

  subgraph RP2040["Waveshare RP2040-LCD-0.99&#34;\n(Display)"]
    direction TB
    R_RX["GPIO 26  SerialPIO RX"]
    R_TX["GPIO 27  SerialPIO TX"]
  end

  subgraph S3["Meshnology ESP32-S3\n(Config + BLE)"]
    direction TB
    S_RX["GPIO 44  Serial0 RX"]
    S_TX["GPIO 43  Serial0 TX"]
  end

  subgraph Phone["iOS App"]
    BLE_APP["SodaMachine\nSwiftUI"]
  end

  %% ── ESP32 ↔ RP2040 UART ──
  E_S2_TX -->|"TX"| R_RX
  R_TX -->|"TX"| E_S2_RX

  %% ── ESP32 ↔ S3 UART ──
  E_S1_TX -->|"TX"| S_RX
  S_TX -->|"TX"| E_S1_RX

  %% ── S3 ↔ Phone BLE ──
  S3 <-.->|"BLE\nconfig, images,\nstats, firmware"| Phone

  %% ── Protocol annotations ──
  PROTO_RP["115200 baud · 8N1\nTinyProto HDLC full-duplex\nRX buffer: 4096 bytes\n\nMessage types:\n  MSG_TEXT — commands/config\n  MSG_UPLOAD_START/DATA/DONE — images\n  MSG_DEVICE_READY — boot handshake"]

  PROTO_S3["115200 baud · 8N1\nTinyProto HDLC full-duplex\nRX buffer: 4096 bytes\n\nMessage types:\n  GET_CONFIG / SET:key=val / SAVE\n  MSG_UPLOAD_START/DATA/DONE — images\n  MSG_DEVICE_READY — boot handshake"]

  PROTO_RP ~~~ E_S2_TX
  PROTO_S3 ~~~ E_S1_TX

  %% Style protocol boxes as notes
  style PROTO_RP fill:#2a2a2a,stroke:#555,color:#aaa,text-align:left
  style PROTO_S3 fill:#2a2a2a,stroke:#555,color:#aaa,text-align:left
