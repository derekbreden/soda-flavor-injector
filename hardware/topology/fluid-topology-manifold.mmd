flowchart LR

  %% =========================
  %% Remote components
  %% =========================
  subgraph Sources["Sources"]
    Tap["Tap Water"]
    Hopper["Hopper"]
    BiBA["BiB A"]
    BiBB["BiB B"]
  end

  subgraph Pumps["Pumps"]
    PA["Pump A"]
    PB["Pump B"]
  end

  subgraph Bags["Bags"]
    BagA[("Bag A")]
    BagB[("Bag B")]
  end

  subgraph Nozzles["Nozzles"]
    NozzleA["Nozzle A"]
    NozzleB["Nozzle B"]
  end

  %% =========================
  %% Manifold
  %% =========================
  subgraph Manifold["Manifold"]
    direction LR

    subgraph SourceSelection["Source Selection"]
      Reg["Flow Regulator"]
      VA["V-A"]
      VB["V-B"]
      YA{{"Y-A"}}
      YB{{"Y-B"}}
      VC["V-C"]
      VD["V-D"]
      VKA["V-K-A"]
      VKB["V-K-B"]
      YKA{{"Y-KA"}}
      YKB{{"Y-KB"}}
    end

    subgraph MfPumps["Pump Junctions"]
      YC{{"Y-C"}}
      YD{{"Y-D"}}
      YF{{"Y-F"}}
      YG{{"Y-G"}}
    end

    subgraph MfNozzles["Nozzle Gates"]
      VG["V-G"]
      VJ["V-J"]
    end

    subgraph MfBags["Bag Circuit"]
      VE["V-E"]
      YE{{"Y-E"}}
      VF["V-F"]
      VH["V-H"]
      YH{{"Y-H"}}
      VI["V-I"]
    end

    %% Source Selection connections
    Reg --> VA
    VA --> YA
    VB --> YA
    YA --> YB
    YB --> VC
    YB --> VD
    VC --> YKA
    VKA --> YKA
    VD --> YKB
    VKB --> YKB

    %% Pump Junctions connections
    YKA --> YC
    YKB --> YF
    YD --> VG
    YD --> VF
    YG --> VJ
    YG --> VI

    %% Bag Circuit connections
    VE --> YC
    VF --> YE
    YE --> VE
    VH --> YF
    VI --> YH
    YH --> VH
  end

  %% =========================
  %% Tube runs (manifold ↔ remote)
  %% =========================
  Tap --> Reg
  Hopper --> VB
  BiBA --> VKA
  BiBB --> VKB

  YC --> PA --> YD
  YF --> PB --> YG

  YE <--> BagA
  YH <--> BagB

  VG --> NozzleA
  VJ --> NozzleB

  %% All edges are fluid-flow (no sensors, no power), so workhorse white.
  %% linkStyle default is safe here because there are no per-index
  %% overrides to color arrowheads on.
  linkStyle default stroke:#ccc,stroke-width:2px
