flowchart LR

  %% =========================
  %% Remote components
  %% =========================
  subgraph Sources["Sources"]
    Tap["Tap Water"]
    Hopper["Hopper"]
    BiB["BiB"]
  end

  subgraph Pumps["Pumps"]
    PA["Pump A"]
    PB["Pump B"]
  end

  subgraph Bags["Bags"]
    BagA[("Bag A")]
    BagB[("Bag B")]
  end

  subgraph Nozzles["Nozzles"]
    NozzleA["Nozzle A"]
    NozzleB["Nozzle B"]
  end

  %% =========================
  %% Manifold
  %% =========================
  subgraph Manifold["Manifold"]
    direction LR

    subgraph InletGates["Inlet Gates"]
      Reg["Flow Regulator"]
      VA["V-A"]
      VB["V-B"]
      VK["V-K"]
    end

    subgraph SourceMerge["Source Merge"]
      YA{{"Y-A"}}
      YI{{"Y-I"}}
    end

    subgraph ChannelSelect["Channel Select"]
      YB{{"Y-B"}}
      VC["V-C"]
      VD["V-D"]
    end

    subgraph PumpACircuit["Pump A Circuit"]
      VE["V-E"]
      YC{{"Y-C"}}
      YD{{"Y-D"}}
      VF["V-F"]
      VG["V-G"]
      YE{{"Y-E"}}
    end

    subgraph PumpBCircuit["Pump B Circuit"]
      VH["V-H"]
      YF{{"Y-F"}}
      YG{{"Y-G"}}
      VI["V-I"]
      VJ["V-J"]
      YH{{"Y-H"}}
    end

    %% Inlet Gates connections
    Reg --> VA
    VA --> YA
    VB --> YA
    VK --> YI

    %% Source Merge connections
    YA --> YI
    YI --> YB

    %% Channel Select connections
    YB --> VC
    YB --> VD

    %% Pump A Circuit connections
    VC --> YC
    VE --> YC
    YD --> VG
    YD --> VF
    VF --> YE
    YE --> VE

    %% Pump B Circuit connections
    VD --> YF
    VH --> YF
    YG --> VJ
    YG --> VI
    VI --> YH
    YH --> VH
  end

  %% =========================
  %% Tube runs (manifold ↔ remote)
  %% =========================
  Tap --> Reg
  Hopper --> VB
  BiB --> VK

  YC --> PA --> YD
  YF --> PB --> YG

  YE <--> BagA
  YH <--> BagB

  VG --> NozzleA
  VJ --> NozzleB
