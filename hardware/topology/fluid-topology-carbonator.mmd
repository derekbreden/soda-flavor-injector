flowchart LR

  subgraph Sources["Sources"]
    Tap["Tap Water"]
    CO2["CO2 Bottle"]
  end

  subgraph WaterSupply["Water Supply"]
    direction LR
    BFP["Backflow Preventer<br/>(ASSE 1022)"]
    PW["Diaphragm Pump<br/>(100 PSI)"]
    CV["Check Valve<br/>(PTFE soft-seat)"]
  end

  subgraph CO2Supply["CO2 Supply"]
    direction LR
    RegCO2["CO2 Regulator<br/>(70-80 PSI)"]
    CV_CO2["Check Valve<br/>(PTFE soft-seat)"]
  end

  subgraph Tank["Carbonator Vessel<br/>316L SS, 5&quot; × 6&quot;, ~1.55 L"]
    direction TB

    P4["Port 4: PRV"]
    P2["Port 2: Water inlet<br/>(free-fall)"]
    P1["Port 1: CO2 inlet<br/>(to sparge stone)"]
    P3["Port 3: Water outlet"]

    SpargeStone["Sparge Stone<br/>(0.5 µm sintered SS)"]
    Headspace(("CO2 Headspace"))
    Water(("Carbonated<br/>Water"))
    Float(("Magnetic Float"))

    P1 --> SpargeStone
    SpargeStone --> Water
    Water -.-> Headspace
    P2 --> Water
    Headspace ==> P4
    Water --> P3
    Float -.-> Water
  end

  subgraph Dispense["Dispense"]
    Faucet["Faucet Lever"]
    Nozzle["Nozzle"]
  end

  PRVOut["PRV Discharge"]
  LevelSense["Level Sense from reed switches"]

  Tap --> BFP --> PW --> CV --> P2
  CO2 --> RegCO2 --> CV_CO2 --> P1
  P3 --> Faucet --> Nozzle
  P4 ==> PRVOut
  Float -.-> LevelSense
  LevelSense -.interlock.-> PW
  Faucet -.lockout.-> PW

  classDef safety stroke:#c00,stroke-width:2px
  classDef code stroke:#c80,stroke-width:2px
  class P4,PRVOut safety
  class BFP code

  %% Default link style: white solid, readable on any background.
  linkStyle default stroke:#ccc,stroke-width:2px
  %% Safety / pressure-relief path: red, thicker. (edges use ==> so
  %% arrowheads inherit the stroke color too.)
  %% Indices: 4 = Headspace ==> P4, 16 = P4 ==> PRVOut.
  linkStyle 4,16 stroke:#c44,stroke-width:3px
  %% Sensor / interlock (dashed) edges: sky blue for distinction.
  %% Indices: 2 = Water -.-> Headspace, 6 = Float -.-> Water,
  %% 17 = Float -.-> LevelSense, 18 = LevelSense -.interlock.-> PW,
  %% 19 = Faucet -.lockout.-> PW.
  linkStyle 2,6,17,18,19 stroke:#6cf,stroke-width:2px
