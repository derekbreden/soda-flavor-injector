flowchart LR

  %% =========================
  %% Shared source / selection module
  %% =========================
  subgraph Selector["Source Selector"]
    direction LR

    Tap["Tap Water"] --> Reg["Flow Regulator"] --> VA["V-A"]
    Hopper["Hopper"] --> VB["V-B"]
    BiB["BiB"] --> VK["V-K"]

    VA --> YA{{"Y-A"}}
    VB --> YA
    YA --> YI{{"Y-I"}}
    VK --> YI
    YI --> YB{{"Y-B"}}
    YB --> VC["V-C"]
    YB --> VD["V-D"]
  end

  %% =========================
  %% Channel A module
  %% =========================
  subgraph PumpLoopA["Channel A Pump Loop"]
    direction LR

    VE["V-E"] --> YC{{"Y-C"}} --> PA["Pump A"] --> YD{{"Y-D"}}
    YD --> VG["V-G"] --> NozzleA["Nozzle A"]
    YD --> VF["V-F"] --> YE{{"Y-E"}}
    YE <--> BagA[("Bag A")]
    YE --> VE
  end

  %% =========================
  %% Channel B module
  %% =========================
  subgraph PumpLoopB["Channel B Pump Loop"]
    direction LR

    VH["V-H"] --> YF{{"Y-F"}} --> PB["Pump B"] --> YG{{"Y-G"}}
    YG --> VJ["V-J"] --> NozzleB["Nozzle B"]
    YG --> VI["V-I"] --> YH{{"Y-H"}}
    YH <--> BagB[("Bag B")]
    YH --> VH
  end

  %% =========================
  %% Cross-module connections
  %% =========================
  VC --> YC
  VD --> YF

  %% Long tube runs (sources, nozzles, cross-module)
  linkStyle 12,13,21,22 stroke:#1a1a1a,stroke-width:4px
  linkStyle 0,2,3,15,18,24,27 stroke:#1a1a1a,stroke-width:2px
  %% Short/negligible connections (V↔Y, Y↔Y, Y↔pump, Y↔bag)
  linkStyle 1,4,5,6,7,8,9,10,11,14,16,17,19,20,23,25,26,28,29,30 stroke:#ccc,stroke-width:2px
