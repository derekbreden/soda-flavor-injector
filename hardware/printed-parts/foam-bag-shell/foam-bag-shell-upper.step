#22925 = ( NAMED_UNIT(*) PLANE_ANGLE_UNIT() SI_UNIT($,.RADIAN.) );
#22926 = ( NAMED_UNIT(*) SI_UNIT($,.STERADIAN.) SOLID_ANGLE_UNIT() );
#22927 = UNCERTAINTY_MEASURE_WITH_UNIT(LENGTH_MEASURE(1.E-02),#22924,
  'distance_accuracy_value','confusion accuracy');
#22928 = PRODUCT_RELATED_PRODUCT_CATEGORY('part',$,(#7));
ENDSEC;
END-ISO-10303-21;
